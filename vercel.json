{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_BASE_PATH": "algoat",
    "VITE_GITHUB_REPO_URL": "https://github.com/ALgoatorg/ALgoat",
    "VITE_GITHUB_UPSTREAM_OWNER": "ALgoatorg",
    "VITE_GITHUB_UPSTREAM_REPO": "ALgoat"
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/pump-api/:path*", "destination": "https://swap-api.pump.fun/:path*" },
    { "source": "/pump-frontend/:path*", "destination": "https://frontend-api.pump.fun/:path*" },
    { "source": "/dex-api/:path*", "destination": "https://api.dexscreener.com/:path*" },
    { "source": "/sol-rpc", "destination": "https://api.mainnet-beta.solana.com/" },
    { "source": "/algoat", "destination": "/algoat/index.html" },
    { "source": "/algoat/(.*)", "destination": "/algoat/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
